# Maintainer: Jaime <j4imefoo@users.noreply.github.com>

pkgname=tbo-git
pkgver=2.0+r272.8ec0fc3
pkgrel=1
pkgdesc="Comic editor built with GTK4"
arch=('x86_64')
url="https://github.com/j4imefoo/TBO"
license=('GPL3')
depends=('gtk4' 'cairo' 'librsvg')
makedepends=('git' 'meson' 'ninja' 'pkgconf')
source=("git+https://github.com/j4imefoo/TBO.git")
sha256sums=('SKIP')

pkgver() {
  cd TBO
  printf "2.0+r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  arch-meson TBO build -Dnls=false -Dtests=false -Dappstream=false -Dlegacy_pixmap_icon=false -Dtutorial_pdf=false
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
}
